# --- Redis (session & encrypted mapping store) ---
# Connection URL. Format: redis://:<password>@<host>:<port>/<db>
# Source of truth for NATIVE dev (uvicorn on the host) — use `localhost`.
# The full Docker stack overrides this to the in-network `redis` service name
# in docker-compose.yml, so the same value works in both worlds.
REDIS_URL=redis://:changeme@localhost:6379/0

# Must match the password embedded in REDIS_URL and the redis service.
REDIS_PASSWORD=changeme

# AES-256 key. MUST be base64 that decodes to EXACTLY 32 bytes.
# Generate with:
#   python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
REDIS_ENCRYPTION_KEY=

# Session lifetime in seconds (mapping TTL). Default: 3600 (1h).
REDIS_SESSION_TTL=3600

# --- LLM providers (all optional at startup; error only on first use) ---
# The model-based router (Epic 5) picks the provider from the request model's
# prefix: "gpt-" -> OpenAI, "claude-" -> Anthropic, "ollama/" -> Ollama. A key is
# needed only on first use of the provider it belongs to (missing key -> 503).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# On native Linux Docker, host.docker.internal may need:
#   extra_hosts: ["host.docker.internal:host-gateway"]  (added in Epic 5)
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Per-request Ollama timeout in seconds (Epic 4). An exceeded call → HTTP 504.
OLLAMA_TIMEOUT=60
# Max output tokens for every Anthropic ("claude-") call (Epic 5; required by the API).
ANTHROPIC_MAX_TOKENS=4096

# --- Defaults ---
# Default model when a request omits "model". Its prefix selects the provider
# (Epic 5). Keep it an "ollama/"-prefixed local model so the keyless, offline demo
# works out of the box; for a live demo set an installed Ollama model
# (e.g. ollama/llama3.2:1b) or a hosted model (gpt-4o, claude-3-5-sonnet-...).
DEFAULT_MODEL=ollama/qwen2.5:3b
