      "value": "http://localhost:8000"
    },
    {
      "key": "sessionId",
      "value": ""
    },
    {
      "key": "pseudonymizedText",
      "value": ""
    },
    {
      "key": "chatSessionId",
      "value": ""
    }
  ]
}
